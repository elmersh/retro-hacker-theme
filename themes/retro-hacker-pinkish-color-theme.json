        "list.hoverForeground": "#FFFFFF",
        "list.inactiveSelectionBackground": "#33003330",
        "list.inactiveSelectionForeground": "#FF1493",
        "list.dropBackground": "#66006640",
        "list.highlightForeground": "#FF00FF",
        "list.errorForeground": "#FF0000",
        "list.warningForeground": "#FF69B4",
        // Activity bar - Magenta accent
        "activityBar.background": "#110011",
        "activityBar.foreground": "#FF00FF",
        "activityBar.border": "#FF1493",
        "activityBar.activeBorder": "#FF1493",
        "activityBar.activeBackground": "#33003330",
        "activityBarBadge.background": "#FF1493",
        "activityBarBadge.foreground": "#000000",
        // Title and tabs - Terminal magenta
        "editorGroup.border": "#FF00FF",
        "titleBar.border": "#FF00FF",
        "icon.foreground": "#FF00FF",
        "editorGroupHeader.tabsBorder": "#FF00FF",
        "editorGroupHeader.tabsBackground": "#100010",
        "titleBar.activeBackground": "#100010",
        "titleBar.activeForeground": "#FF00FF",
        "titleBar.inactiveBackground": "#000000",
        "titleBar.inactiveForeground": "#66006680",
        "tab.activeBackground": "#000000",
        "tab.activeForeground": "#FF00FF",
        "tab.inactiveBackground": "#00000000",
        "tab.inactiveForeground": "#66006680",
        "tab.hoverBackground": "#000000",
        "tab.hoverBorder": "#FF1493",
        "tab.hoverForeground": "#FF1493",
        "tab.border": "#FF00FF",
        "tab.activeBorder": "#000000",
        "tab.activeModifiedBorder": "#FF69B4",
        "tab.inactiveModifiedBorder": "#FF69B460",
        "tab.unfocusedActiveBorder": "#66006660",
        "tab.activeBorderTop": "#FF1493",
        "tab.unfocusedActiveBorderTop": "#66006680",
        // Status bar - Terminal magenta
        "statusBar.background": "#110011",
        "statusBar.foreground": "#FF00FF",
        "statusBar.border": "#FF1493",
        "statusBar.debuggingBackground": "#330033",
        "statusBar.debuggingForeground": "#FF00FF",
        "statusBar.debuggingBorder": "#FF1493",
        "statusBar.noFolderBackground": "#000000",
        "statusBar.noFolderForeground": "#FF00FF",
        "statusBar.noFolderBorder": "#FF1493",
        "statusBarItem.hoverBackground": "#FF00FF40",
        "statusBarItem.remoteBackground": "#FF1493",
        "statusBarItem.remoteForeground": "#000000",
        // Terminal panel - Terminal magenta
        "panel.background": "#000000",
        "panel.border": "#FF1493",
        "panelTitle.activeBorder": "#FF1493",
        "panelTitle.activeForeground": "#FF00FF",
        "panelTitle.inactiveForeground": "#66006680",
        "panelInput.border": "#FF1493",
        // Panel section headers - Magenta accent
        "panelSectionHeader.background": "#330033",
        "panelSectionHeader.foreground": "#FF00FF",
        "panelSectionHeader.border": "#FF1493",
        // Terminal - Magenta terminal classic
        "terminal.background": "#000000",
        "terminal.foreground": "#FF00FF",
        "terminal.ansiBlack": "#000000",
        "terminal.ansiBrightBlack": "#333333",
        "terminal.ansiBlue": "#FF1493",
        "terminal.ansiBrightBlue": "#FF69B4",
        "terminal.ansiCyan": "#FF1493",
        "terminal.ansiBrightCyan": "#FF69B4",
        "terminal.ansiGreen": "#FF00FF",
        "terminal.ansiBrightGreen": "#FF00FF",
        "terminal.ansiMagenta": "#FF69B4",
        "terminal.ansiBrightMagenta": "#FFAADD",
        "terminal.ansiRed": "#FF0000",
        "terminal.ansiBrightRed": "#FF3333",
        "terminal.ansiWhite": "#CCCCCC",
        "terminal.ansiBrightWhite": "#FFFFFF",
        "terminal.ansiYellow": "#FF69B4",
        "terminal.ansiBrightYellow": "#FFAADD",
        // Tab del terminal y paneles - Magenta borders
        "terminal.tab.activeBorder": "#FF1493",
        "panelSection.border": "#FF1493",
        "panelSection.dropBackground": "#FF00FF40",
        // Barra de comandos del terminal - Magenta feedback
        "terminalCommandDecoration.defaultBackground": "#33003320",
        "terminalCommandDecoration.successBackground": "#66006640",
        "terminalCommandDecoration.errorBackground": "#33000040",
        // Editor widgets - Magenta glow
        "editorHoverWidget.background": "#110011",
        "editorHoverWidget.border": "#FF1493",
        "editorHoverWidget.foreground": "#FF00FF",
        "editorHoverWidget.statusBarBackground": "#330033",
        // Panel de comandos
        "commandCenter.background": "#110011",
        "commandCenter.border": "#FF1493",
        "commandCenter.activeBackground": "#330033",
        "commandCenter.foreground": "#FF00FF",
        "commandCenter.activeForeground": "#FF00FF",
        "commandCenter.activeBorder": "#FF1493",
        "quickInput.background": "#110011",
        "quickInput.foreground": "#FF00FF",
        "quickInputList.focusBackground": "#330033",
        "quickInputList.focusForeground": "#FFFFFF",
        "quickInputTitle.background": "#110011",
        "quickInputList.focusIconForeground": "#FF1493",
        // Input controls - Magenta inputs
        "input.background": "#110011",
        "input.foreground": "#FF00FF",
        "input.border": "#FF1493",
        "input.placeholderForeground": "#66006680",
        "inputOption.activeBackground": "#FF00FF40",
        "inputOption.activeBorder": "#FF1493",
        "inputValidation.errorBackground": "#33000020",
        "inputValidation.errorBorder": "#FF0000",
        "inputValidation.warningBackground": "#33003320",
        "inputValidation.warningBorder": "#FF69B4",
        // Scrollbar - Magenta glow
        "scrollbarSlider.background": "#66006640",
        "scrollbarSlider.hoverBackground": "#99009950",
        "scrollbarSlider.activeBackground": "#FF00FF60",
        "scrollbar.shadow": "#00000080",
        // Breadcrumbs - Magenta navigation
        "breadcrumb.foreground": "#99009990",
        "breadcrumb.focusForeground": "#FF00FF",
        "breadcrumb.activeSelectionForeground": "#FFFFFF",
        "breadcrumbPicker.background": "#110011",
        // Settings - Terminal interface
        "settings.headerForeground": "#FF00FF",
        "settings.modifiedItemIndicator": "#FF69B4",
        "settings.checkboxBackground": "#110011",
        "settings.checkboxForeground": "#FF00FF",
        "settings.checkboxBorder": "#FF1493",
        // Debug - Magenta feedback
        "debugToolBar.background": "#110011",
        "debugToolBar.border": "#FF1493",
        "debugIcon.breakpointForeground": "#FF0000",
        "debugIcon.startForeground": "#FF00FF",
        // Git decorations - Magenta status
        "gitDecoration.modifiedResourceForeground": "#FF69B4",
        "gitDecoration.deletedResourceForeground": "#FF0000",
        "gitDecoration.untrackedResourceForeground": "#FF00FF",
        "gitDecoration.ignoredResourceForeground": "#66006660",
        "gitDecoration.conflictingResourceForeground": "#FFCC00",
        "gitDecoration.submoduleResourceForeground": "#FF69B4",
        // Context menu - Magenta dropdown
        "menu.background": "#110011",
        "menu.foreground": "#FF00FF",
        "menu.selectionBackground": "#FF00FF40",
        "menu.selectionForeground": "#FFFFFF",
        "menu.separatorBackground": "#FF1493",
        "menu.border": "#FF1493",
        "menu.selectionBorder": "#FF1493",
        // Notifications - Magenta alerts
        "notificationCenter.border": "#FF1493",
        "notificationCenterHeader.foreground": "#FF00FF",
        "notificationCenterHeader.background": "#110011",
        "notificationToast.border": "#FF1493",
        "notifications.foreground": "#FF00FF",
        "notifications.background": "#110011",
        "notifications.border": "#FF1493",
        "notificationLink.foreground": "#FF1493",
        // Buttons - Magenta controls
        "button.background": "#FF00FF",
        "button.foreground": "#000000",
        "button.hoverBackground": "#FF1493",
        "button.secondaryBackground": "#FF00FF30",
        "button.secondaryForeground": "#FF00FF",
        "button.secondaryHoverBackground": "#FF00FF45",
        "button.border": "#FF1493",
        // Extensions - Magenta marketplace
        "extensionButton.prominentBackground": "#FF00FF",
        "extensionButton.prominentHoverBackground": "#FF1493",
        "extensionIcon.starForeground": "#FF69B4",
        // Welcome page
        "welcomePage.background": "#110011",
        "welcomePage.progress.background": "#FF00FF",
        "welcomePage.progress.foreground": "#FF00FF",
        "walkThrough.embeddedEditorBackground": "#110011"
    },
    "tokenColors": [
        {
            "scope": "emphasis",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "strong",
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment",
                "string.comment"
            ],
            "settings": {
                "foreground": "#66006680",
                "fontStyle": "italic"
            }
        },
        {
            "name": "String and Templates",
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.interpolated",
                "string.regexp",
                "string.tag",
                "string.value"
            ],
            "settings": {
                "foreground": "#FFAADD"
            }
        },
        {
            "scope": [
                "storage.modifier.async.js",
                "storage.type.js"
            ],
            "settings": {
                "foreground": "#FF00FF",
                "fontStyle": "bold"
            }
        },
        {
            "name": "JavaScript Template Expression",
            "scope": [
                "punctuation.definition.template-expression.begin",
                "punctuation.definition.template-expression.end"
            ],
            "settings": {
                "foreground": "#FF69B4"
            }
        },
        {
            "name": "Operators and Delimiters",
            "scope": [
                "keyword.operator",
                "punctuation.separator",
                "punctuation.definition"
            ],
            "settings": {
                "foreground": "#FF1493"
            }
        },
        {
            "name": "Tags and Attributes",
            "scope": [
                "entity.name.tag",
                "entity.other.attribute-name",
                "meta.tag"
            ],
            "settings": {
                "foreground": "#FF00FF",
                "fontStyle": "bold"
            }
        },
        {
            "name": "CSS Selectors",
            "scope": [
                "entity.other.attribute-name.class",
                "entity.other.attribute-name.id",
                "entity.other.attribute-name.pseudo-class",
                "entity.other.attribute-name.pseudo-element"
            ],
            "settings": {
                "foreground": "#FF69B4"
            }
        },
        {
            "name": "CSS Units",
            "scope": [
                "keyword.other.unit"
            ],
            "settings": {
                "foreground": "#FF69B4"
            }
        },
        {
            "name": "Numbers and Constants",
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.other.color.rgb-value",
                "constant.other.rgb-value",
                "support.constant.color",
                "constant.other",
                "constant.character"
            ],
            "settings": {
                "foreground": "#FF69B4"
            }
        },
        {
            "name": "Functions and Methods",
            "scope": [
                "entity.name.function",
                "support.function",
                "support.constant.handlebars",
                "meta.function-call",
                "meta.method-call",
                "meta.function.parameters"
            ],
            "settings": {
                "foreground": "#FF1493",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Keywords and Control",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control",
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.cast",
                "keyword.operator.sizeof"
            ],
            "settings": {
                "foreground": "#FF00FF",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Types and Classes",
            "scope": [
                "entity.name.type",
                "support.type",
                "support.class",
                "storage.type.built-in",
                "meta.return-type",
                "meta.type.cast.expr",
                "meta.type.new.expr",
                "support.constant.math",
                "support.constant.dom",
                "support.constant.json",
                "entity.other.inherited-class",
                "entity.name.class",
                "source.cs storage.type"
            ],
            "settings": {
                "foreground": "#FF69B4",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Variables and Parameters",
            "scope": [
                "variable",
                "support.variable",
                "variable.other",
                "variable.language",
                "variable.parameter",
                "meta.definition.variable.name",
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#FF00FF"
            }
        },
        {
            "name": "Language Variables",
            "scope": [
                "variable.language.this",
                "variable.language.super",
                "variable.language.self"
            ],
            "settings": {
                "foreground": "#FF69B4",
                "fontStyle": "italic bold"
            }
        },
        {
            "name": "Punctuation and Brackets",
            "scope": [
                "punctuation",
                "meta.brace",
                "meta.brackets",
                "meta.parentheses",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#FF00FF"
            }
        },
        {
            "name": "HTML/XML Tags",
            "scope": [
                "entity.name.tag",
                "entity.name.tag.css",
                "entity.other.attribute-name",
                "source.css entity.other.attribute-name",
                "source.css.less entity.other.attribute-name.id",
                "source.scss entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#FF00FF",
                "fontStyle": "bold"
            }
        },
        {
            "name": "CSS Properties and Values",
            "scope": [
                "support.type.property-name.css",
                "support.type.property-name.scss",
                "support.type.property-name.less",
                "support.type.property-name.sass",
                "support.type.vendored.property-name",
                "support.constant.property-value",
                "support.constant.font-name",
                "support.constant.media-type",
                "support.constant.media"
            ],
            "settings": {
                "foreground": "#FF1493"
            }
        },
        {
            "name": "Markdown",
            "scope": [
                "markup.heading",
                "markup.bold",
                "markup.italic",
                "markup.inserted",
                "markup.deleted",
                "markup.changed",
                "markup.underline"
            ],
            "settings": {
                "foreground": "#FF00FF"
            }
        },
        {
            "name": "Invalid",
            "scope": [
                "invalid",
                "invalid.illegal",
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#FF0000",
                "fontStyle": "bold underline"
            }
        },
        {
            "name": "Git and Version Control",
            "scope": [
                "support.function.git-rebase",
                "constant.sha.git-rebase",
                "meta.diff.header"
            ],
            "settings": {
                "foreground": "#FF1493"
            }
        },
        {
            "name": "",
            "scope": [
                "entity.name.type.namespace.cs"
            ],
            "settings": {
                "foreground": "#FF69B4",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name.html"
            ],
            "settings": {
                "foreground": "#FF69B4",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "punctuation.definition.entity.html"
            ],
            "settings": {
                "foreground": "#FF1493",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#FF00FF",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "punctuation.support.type.property-name"
            ],
            "settings": {
                "foreground": "#FF69B4",
                "fontStyle": "bold"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "namespace": "#FF69B4",
        "type": "#FF69B4",
        "class": "#FF69B4",
        "enum": "#FF69B4",
        "interface": "#FF69B4",
        "struct": "#FF69B4",
        "typeParameter": "#FF69B4",
        "parameter": "#FF00FF",
        "variable": "#FF00FF",
        "property": "#FF1493",
        "enumMember": "#FF69B4",
        "event": "#FF1493",
        "function": "#FF1493",
        "method": "#FF1493",
        "macro": "#FF00FF",
        "keyword": "#FF00FF",
        "modifier": "#FF00FF",
        "comment": "#66006680",
        "string": "#FFAADD",
        "number": "#FF69B4",
        "regexp": "#FFAADD",
        "operator": "#FF1493",
        "decorator": "#FF69B4"
    }
}
