        "editorCodeLens.foreground": "#99009980",
        "editorError.foreground": "#FF0000",
        "editorError.border": "#FF000080",
        "editorWarning.foreground": "#FF69B4",
        "editorWarning.border": "#FF69B480",
        "editorInfo.foreground": "#FF1493",
