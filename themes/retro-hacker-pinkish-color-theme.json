{
    "name": "Retro Hacker Magenta",
    "type": "dark",
    "colors": {
        // Base colors - Retro Magenta CRT Terminal
        "foreground": "#FF00FF",
        "focusBorder": "#FF1493",
        "selection.background": "#FF00FF40",
        "descriptionForeground": "#FF69B4",
        "errorForeground": "#FF0000",
        "widget.shadow": "#FF00FF30",
        "widget.border": "#FF00FF",
        // Editor - Magenta CRT effect
        "editor.background": "#000000",
        "editor.foreground": "#FF00FF",
        "editor.lineHighlightBackground": "#33003310",
        "editor.lineHighlightBorder": "#66006620",
        "editor.selectionBackground": "#FF00FF40",
        "editor.wordHighlightBackground": "#FF00FF30",
        "editor.wordHighlightStrongBackground": "#FF00FF50",
        "editor.findMatchBackground": "#FF149360",
        "editor.findMatchHighlightBackground": "#FF149330",
        "editor.findRangeHighlightBackground": "#FF69B420",
        "editor.hoverHighlightBackground": "#33003315",
